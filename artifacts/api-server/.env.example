# API server environment example
PORT=8080
DATABASE_URL=postgres://user:pass@localhost:5432/dbname
# Public-facing origin (Netlify URL in prod, vite dev URL locally). Used to
# build Strava OAuth + webhook callback URLs.
APP_PUBLIC_URL=http://localhost:3000
CLERK_PUBLISHABLE_KEY=pk_your_publishable_key_here
CLERK_SECRET_KEY=sk_your_secret_key_here
STRIPE_SECRET_KEY=sk_your_secret_key_here
STRIPE_PRICE_ID_ATHLETE=price_your_athlete_price_id_here
STRIPE_PRICE_ID_COACH_BASE=price_your_coach_base_price_id_here
STRIPE_PRICE_ID_COACH_ADDITIONAL=price_your_coach_additional_price_id_here
# Optional: use payment mode instead of subscription.
STRIPE_PRICE_MODE=subscription
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
OPENAI_API_KEY=
# AveraAI coach (GLM-4-Flash). Optional for boot, required for /api/openai routes.
GLM_API_KEY=
 